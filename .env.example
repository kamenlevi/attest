# Copy this file to ".env" and paste your real key there.
#   cp .env.example .env
# .env is git-ignored, so your key never gets committed or pushed.
# Attest loads .env automatically when you run a command.

# OpenRouter (you have a key for this):
ATTEST_BASE_URL=https://openrouter.ai/api/v1
ATTEST_MODEL=meta-llama/llama-3.1-8b-instruct
ATTEST_API_KEY=paste-your-openrouter-key-here

# Examples for other providers (uncomment one instead):
# Groq (free, fast):
# ATTEST_BASE_URL=https://api.groq.com/openai/v1
# ATTEST_MODEL=llama-3.1-8b-instant
# Local Ollama (no key needed):
# ATTEST_BASE_URL=http://localhost:11434/v1
# ATTEST_MODEL=llama3.2:1b
